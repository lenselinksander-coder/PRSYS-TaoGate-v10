# ── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL=postgres://user:password@localhost:5432/prsys

# ── Server ────────────────────────────────────────────────────────────────────
PORT=5000
NODE_ENV=development

# ── Perplexity AI (optional — for research/ingest features) ───────────────────
PERPLEXITY_API_KEY=

# ── Feature 2: WORM Audit Chain (S3 Object Lock) ─────────────────────────────
# Leave WORM_S3_BUCKET empty to disable WORM — the system falls back to
# PostgreSQL-only audit logging. No error is raised if unset.
#
# Prerequisites:
#   1. Create an S3 bucket with Object Lock ENABLED at bucket creation time.
#      (Object Lock cannot be enabled on existing buckets.)
#   2. Set the default retention: COMPLIANCE mode, 7 years.
#   3. IAM permissions required: s3:PutObject, s3:GetObject, s3:ListBucket
#
WORM_S3_BUCKET=
AWS_REGION=eu-west-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
